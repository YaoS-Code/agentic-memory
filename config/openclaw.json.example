{
  "// INSTRUCTIONS": "Copy this to ~/.openclaw/openclaw.json and fill in your values",

  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": ["anthropic/claude-haiku-4-5"]
      },
      "workspace": "~/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "sandbox": {
        "mode": "off"
      }
    },
    "list": [{
      "id": "main",
      "tools": {
        "profile": "coding",
        "allow": [
          "group:fs",
          "group:runtime",
          "group:web",
          "group:memory",
          "group:sessions",
          "group:automation"
        ],
        "exec": {
          "security": "full",
          "ask": "off",
          "host": "gateway",
          "timeoutSec": 300,
          "strictInlineEval": false
        }
      }
    }]
  },

  "plugins": {
    "allow": ["memory-api"],
    "load": {
      "paths": ["~/.openclaw/plugins/memory-api"]
    },
    "slots": {
      "memory": "memory-api"
    },
    "entries": {
      "memory-api": {
        "enabled": true,
        "config": {
          "apiUrl": "http://localhost:18800",
          "maxResults": 8
        }
      }
    }
  },

  "tools": {
    "profile": "coding",
    "fs": {
      "workspaceOnly": false
    },
    "exec": {
      "security": "full",
      "ask": "off",
      "host": "gateway",
      "timeoutSec": 300,
      "strictInlineEval": false
    }
  },

  "// IMPORTANT": "Do NOT use profile: 'full' — it has an empty allowlist and will disable exec/read/write/edit. Use 'coding' instead. See docs/UPGRADE-2026.3.28.md for details."
}
